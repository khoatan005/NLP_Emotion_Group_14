    "axes[0].plot(log_df[\"epoch\"], log_df[\"val_loss\"],   label=\"Val Loss\",   marker=\"o\", markersize=3)\n",
    "axes[0].set_xlabel(\"Epoch\"); axes[0].set_ylabel(\"Loss\")\n",
    "axes[0].set_title(\"Loss Curve\"); axes[0].legend(); axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "# F1\n",
    "axes[1].plot(log_df[\"epoch\"], log_df[\"val_micro_f1\"],    label=\"Micro F1\",    marker=\"o\", markersize=3)\n",
    "axes[1].plot(log_df[\"epoch\"], log_df[\"val_macro_f1\"],    label=\"Macro F1\",    marker=\"o\", markersize=3)\n",
    "axes[1].plot(log_df[\"epoch\"], log_df[\"val_weighted_f1\"], label=\"Weighted F1\", marker=\"o\", markersize=3)\n",
    "axes[1].set_xlabel(\"Epoch\"); axes[1].set_ylabel(\"F1\")\n",
    "axes[1].set_title(\"Val F1 Curves\"); axes[1].legend(); axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(result[\"run_dir\"], \"logs\", \"training_curves.png\"), dpi=150)\n",
