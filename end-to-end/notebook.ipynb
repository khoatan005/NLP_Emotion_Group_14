  {
   "cell_type": "markdown",
   "id": "s7",
   "metadata": {},
   "source": [
    "## 7. Inference on New Text (optional)\n",
    "Run predictions on arbitrary sentences."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "inference",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import numpy as np\n",
    "from transformers import AutoTokenizer\n",
    "from src.train import build_model\n",
    "from src.dataloader import CLASS_NAMES, BACKBONE_REGISTRY\n",
    "from src.utils import load_config\n",
    "\n",
    "cfg    = load_config(CONFIG_PATH)\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "# Load checkpoint\n",
    "ckpt_path = os.path.join(result[\"run_dir\"], \"checkpoints\", \"best.pth\")\n",
    "ckpt      = torch.load(ckpt_path, map_location=device, weights_only=False)\n",
    "model     = build_model(cfg[\"e2e\"], num_labels=ckpt[\"num_labels\"]).to(device)\n",
    "model.load_state_dict(ckpt[\"model_state\"])\n",
    "model.eval()\n",
    "\n",
    "model_name = cfg[\"e2e\"][\"model\"][\"name\"]\n",
    "pretrained = BACKBONE_REGISTRY[model_name][\"pretrained\"]\n",
    "tokenizer  = AutoTokenizer.from_pretrained(pretrained)\n",
    "max_length = int(cfg[\"data\"].get(\"max_length\", 128))\n",
    "\n",
    "# Use the best thresholds found during evaluation\n",
    "best_ts = eval_result[\"best_thresholds\"]\n",
    "\n",
    "def predict(texts):\n",
    "    enc = tokenizer(\n",
    "        texts,\n",
    "        max_length=max_length,\n",
    "        padding=\"max_length\",\n",
    "        truncation=True,\n",
    "        return_tensors=\"pt\",\n",
    "    )\n",
    "    with torch.no_grad():\n",
    "        logits = model(\n",
    "            enc[\"input_ids\"].to(device),\n",
    "            enc[\"attention_mask\"].to(device),\n",
    "        )\n",
    "    probs = torch.sigmoid(logits).float().cpu().numpy()\n",
    "    preds = (probs >= best_ts).astype(int)\n",
    "    results = []\n",
    "    for i, text in enumerate(texts):\n",
    "        predicted = [CLASS_NAMES[j] for j in range(len(CLASS_NAMES)) if preds[i, j] == 1]\n",
    "        if not predicted:\n",
    "            predicted = [CLASS_NAMES[np.argmax(probs[i])]]\n",
    "        results.append({\"text\": text, \"predicted\": predicted,\n",
    "                        \"probs\": {CLASS_NAMES[j]: round(float(probs[i, j]), 3)\n",
    "                                  for j in range(len(CLASS_NAMES))}})\n",
    "    return results\n",
    "\n",
    "# ── Test sentences ────────────────────────────────────────────────────────────\n",
    "test_texts = [\n",
    "    \"I am so happy today, everything went perfectly!\",\n",
    "    \"This is absolutely disgusting, I can't believe they did that.\",\n",
    "    \"I'm really scared about what might happen next.\",\n",
    "    \"The weather is nice today.\",\n",
    "    \"I feel so angry and disappointed at the same time.\",\n",
    "]\n",
    "\n",
    "for res in predict(test_texts):\n",
    "    print(f\"Text      : {res['text']}\")\n",
    "    print(f\"Predicted : {res['predicted']}\")\n",
    "    top3 = sorted(res['probs'].items(), key=lambda x: -x[1])[:3]\n",
    "    print(f\"Top probs : {top3}\")\n",
    "    print()"
   ]
  }
 ]
}"
