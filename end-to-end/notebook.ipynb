  {
   "cell_type": "code",
   "execution_count": null,
   "id": "data_preview",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "data_dir    = os.path.join(PROJECT_ROOT, cfg[\"data\"][\"data_dir\"])\n",
    "train_file  = os.path.join(data_dir, cfg[\"data\"][\"train_file\"])\n",
